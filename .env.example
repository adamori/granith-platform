DATABASE_URL=postgresql://granith:granith@localhost:5432/granith
OPAQUE_SERVER_SETUP=
ADMIN_KEY=change-me-to-a-long-random-string-at-least-32-chars
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Server-side key for encrypting notification driver credentials at rest (NOT end-to-end; the server can read these).
NOTIFY_ENCRYPTION_KEY=change-me-to-a-long-random-string-at-least-32-chars
# Externally reachable base URL for Approve/Deny links (e.g. https://api.granith.dev). Not a secret.
PUBLIC_API_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
# Production: CORS_ORIGIN=https://app.granith.dev
NODE_ENV=development
TRUST_PROXY=
BODY_LIMIT=524288
