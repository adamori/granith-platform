---
interface Props {
  class?: string;
}
const { class: cls = "" } = Astro.props;
---

<span
  class={`inline-flex items-center gap-2 rounded-sm border border-[#2e2e3e] bg-[#14141f]/60 px-2 py-1 text-[10px] uppercase tracking-[0.18em] text-[#8b8ba0] ${cls}`}
>
  <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#22c55e]" aria-hidden="true"></span>
  v1.0
</span>
