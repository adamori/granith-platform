---
const year = new Date().getFullYear();
---

<footer class="relative z-10 mt-32 border-t border-[#2e2e3e]/60 bg-[#0a0a0f]">
  <div class="mx-auto max-w-6xl px-5 py-10 sm:px-8">
    <div class="grid gap-8 sm:grid-cols-2">
      <div>
        <div class="text-sm font-semibold tracking-wide text-[#e4e4ef]">granith</div>
        <p class="mt-2 max-w-xs text-xs leading-relaxed text-[#8b8ba0]">
          A zero-knowledge secrets manager. Server stores ciphertext; your SDK decrypts.
          Currently single-user.
        </p>
      </div>
      <div class="sm:text-right">
        <div class="text-[10px] uppercase tracking-[0.18em] text-[#8b8ba0]">product</div>
        <ul class="mt-3 space-y-1.5 text-sm">
          <li><a href="https://app.granith.dev" class="hover:text-[#6366f1]">open app</a></li>
          <li><a href="https://app.granith.dev/register" class="hover:text-[#6366f1]">create account</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-10 flex items-center justify-between border-t border-[#2e2e3e]/60 pt-5 text-[11px] text-[#8b8ba0]">
      <span>© {year} granith</span>
      <span>spec v1.0.0</span>
    </div>
  </div>
</footer>
